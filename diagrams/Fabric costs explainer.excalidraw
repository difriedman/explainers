      "isDeleted": false,
      "boundElements": [],
      "updated": 1773369878019,
      "link": null,
      "locked": false,
      "text": "Consumption is billed in 30-\nsecond windows, ostensibly\nlimited by the capacity\navailable in the associated F-\nSKU",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Consumption is billed in 30-second windows, ostensibly limited by the capacity available in the associated F-SKU",
      "autoResize": false,
      "lineHeight": 1.25
    },
