      "version": 878,
      "versionNonce": 1752870793,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773370252016,
      "link": null,
      "locked": false,
      "text": "Even with smoothing, it is possible to exceed the allotted\ncapacity for a given 30-second window",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Even with smoothing, it is possible to exceed the allotted capacity for a given 30-second window",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "xNlrcuEzBKL8s1G895qpn",
      "type": "text",
      "x": 298.2248909202853,
      "y": 2490.2305945393587,
      "width": 495.02959438437324,
      "height": 40,
      "angle": 0,
      "strokeColor": "#ffffff",
      "backgroundColor": "#fa5252",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
