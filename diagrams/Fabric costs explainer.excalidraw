    {
      "id": "6JKiA3CeFbFBCbBdeK_bf",
      "type": "text",
      "x": 297.9702578647901,
      "y": 2546.8892504805603,
      "width": 521.6629069371468,
      "height": 120,
      "angle": 0,
      "strokeColor": "#ffffff",
      "backgroundColor": "#fa5252",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "v8cmyqadk2HtaqyKkqM4m"
      ],
      "frameId": null,
      "index": "b3j",
      "roundness": null,
      "seed": 1215967689,
      "version": 1202,
      "versionNonce": 1892671655,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773370252016,
      "link": null,
      "locked": false,
      "text": "Usage billed in a 30-second window:\n\n<10 minutes =  No throttling\n10-60 minutes = interactive jobs delayed 20 seconds\n1-24 hours = Interactive jobs rejected\n>24 hours = Background and interactive jobs rejected",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Usage billed in a 30-second window:\n\n<10 minutes =  No throttling\n10-60 minutes = interactive jobs delayed 20 seconds\n1-24 hours = Interactive jobs rejected\n>24 hours = Background and interactive jobs rejected",
      "autoResize": false,
      "lineHeight": 1.25
    },
