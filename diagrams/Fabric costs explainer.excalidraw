      "updated": 1773370057797,
      "link": null,
      "locked": false,
      "text": "CU's can pay for ANY workload\nin Fabric (Power BI, Pipelines,\nSpark, Real-time Intelligence,\nData Warehouse, Copilot, etc.)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CU's can pay for ANY workload in Fabric (Power BI, Pipelines, Spark, Real-time Intelligence, Data Warehouse, Copilot, etc.)",
      "autoResize": false,
      "lineHeight": 1.25
    },
