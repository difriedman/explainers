    {
      "id": "V6LkkwLx-LihoKo3cBHvC",
      "type": "text",
      "x": 201.46472377315376,
      "y": 1594.7768245886043,
      "width": 242.6253414320058,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#99e9f2",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "0IRGtoAOKLuCsxZcMyxFS"
      ],
      "frameId": null,
      "index": "b1UWV",
      "roundness": null,
      "seed": 1726736489,
      "version": 588,
      "versionNonce": 403064007,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773370113273,
      "link": null,
      "locked": false,
      "text": "Bursting lets you consume\nextra compute to speed the\nexecution of a workload. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bursting lets you consume extra compute to speed the execution of a workload. ",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Rtr0wUT-HFqsYe0z_CvDy",
      "type": "text",
      "x": 199.02365944193087,
      "y": 1671.4100118784595,
      "width": 242.6253414320058,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "C6pmhfqaJLGDKntZKmVv3",
        "0IRGtoAOKLuCsxZcMyxFS"
      ],
      "frameId": null,
      "index": "b1UX",
      "roundness": null,
      "seed": 1390524745,
      "version": 949,
      "versionNonce": 14982023,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773429412612,
      "link": null,
      "locked": false,
      "text": "An example: A notebook might\nconsume 20,000 CU's. On an\nF64, at 1,920 CU's per 30-\nsecond window, it should take\n~5 minutes. With bursting, the\njob might actually run in just\n1-2 minutes.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "An example: A notebook might consume 20,000 CU's. On an F64, at 1,920 CU's per 30-second window, it should take ~5 minutes. With bursting, the job might actually run in just 1-2 minutes.",
      "autoResize": false,
      "lineHeight": 1.25
    },
