      ],
      "frameId": null,
      "index": "b3hV",
      "roundness": null,
      "seed": 524674791,
      "version": 889,
      "versionNonce": 1970317703,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773370252016,
      "link": null,
      "locked": false,
      "text": "The result is a temporary delay/rejection of new operations\n(in-flight operations not affected)",
